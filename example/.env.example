# DATABASE
# Use a strong unique username/password and prefer TLS in non-local deployments.
POSTGRES_USER="trackables"
POSTGRES_PASSWORD="change-this-to-a-long-random-secret"
DATABASE_URL="postgresql://trackables:change-this-to-a-long-random-secret@localhost:5432/trackables"
# Optional hardening for managed Postgres deployments.
# DATABASE_SSL_MODE="require"
# DATABASE_SSL_REJECT_UNAUTHORIZED="true"

# AUTH
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_...."
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."
CLERK_ISSUER_URL="https://clerk.your-domain.com/oauth/authorize"
# APP RUNTIME
NEXT_PUBLIC_APP_URL="http://localhost:3000"
REDIS_URL="redis://redis:6379"

# Optional Lemon Squeezy billing secrets when workspace billing is enabled.
# LEMON_SQUEEZY_API_KEY="ls_api_..."
# LEMON_SQUEEZY_WEBHOOK_SECRET="whsec_..."

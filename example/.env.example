# DATABASE
# Use a strong unique username/password and prefer TLS in non-local deployments.
POSTGRES_USER="trackables"
POSTGRES_PASSWORD="change-this-to-a-long-random-secret"
DATABASE_URL="postgresql://trackables:change-this-to-a-long-random-secret@localhost:5432/trackables"
# Optional hardening for managed Postgres deployments.
# DATABASE_SSL_MODE="require"
# DATABASE_SSL_REJECT_UNAUTHORIZED="true"
# AUTH
# you must setup clerk publishable key in clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
# find secret key in clerk project
CLERK_SECRET_KEY="sk_test_...."
# create webhook in clerk at https://<domain>/api/clerk/webhook with events:
# user.created, user.deleted, user.updated
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."
# Optional API ingress hardening knobs.
# API_USAGE_MAX_BODY_BYTES="65536"
# API_USAGE_INVALID_KEY_RATE_LIMIT_PER_MINUTE="30"
# Optional trackable asset storage. In Docker, point this at the mounted upload volume.
# TRACKABLE_ASSET_STORAGE_ROOT="/data/uploads"
# TRACKABLE_ASSET_MAX_UPLOAD_BYTES="10485760"
# Optional usage events page size override for dashboard log windows.
# USAGE_EVENT_PAGE_SIZE="101"
# Queue-driven webhook delivery uses Redis and can be tuned here if needed.
# REDIS_URL="redis://localhost:6379"
# WEBHOOK_QUEUE_ENABLED="true"
# WEBHOOK_QUEUE_RATE_LIMIT_MS="1000"
# WEBHOOK_QUEUE_RATE_LIMIT_MAX="1"

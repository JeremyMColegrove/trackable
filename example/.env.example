# DATABASE
# Use a strong unique username/password and prefer TLS in non-local deployments.
POSTGRES_USER="trackables"
POSTGRES_PASSWORD="change-this-to-a-long-random-secret"
POSTGRES_DB="trackables"
DATABASE_URL="postgresql://trackables:change-this-to-a-long-random-secret@localhost:5432/trackables"
# Optional hardening for managed Postgres deployments.
# DATABASE_SSL_MODE="require"
# DATABASE_SSL_REJECT_UNAUTHORIZED="true"

# AUTH
BETTER_AUTH_SECRET="change-this-to-a-long-random-secret"
# Must match your app's public URL
BETTER_AUTH_URL="http://localhost:3000"

# Microsoft OAuth (optional — for "Sign in with Microsoft")
# Register an app in Azure AD and set the redirect URI to:
# {BETTER_AUTH_URL}/api/auth/callback/microsoft
# MICROSOFT_CLIENT_ID="..."
# MICROSOFT_CLIENT_SECRET="..."
# MICROSOFT_TENANT_ID="common"

# OPTIONAL EMAIL QUEUE OVERRIDES
# Trackables only enqueues rendered auth emails into Redis.
# A separate worker or sidecar should consume the queue and send the email.
# The built-in defaults are shown below in case you want to align an external worker.
# EMAIL_QUEUE_NAME="email-queue"
# EMAIL_QUEUE_JOB_NAME="email-queue-job"

# APP RUNTIME
NEXT_PUBLIC_APP_URL="http://localhost:3000"
REDIS_URL="redis://redis:6379"
# Auth email delivery is controlled in config.json via auth.emailServiceEnabled.
# This app only enqueues rendered emails into Redis; a separate worker is
# responsible for actually sending them. Self-hosters can fork
# https://github.com/JeremyMColegrove/trackables-email for that queue consumer.

# Optional Lemon Squeezy billing secrets when workspace billing is enabled.
# LEMON_SQUEEZY_API_KEY="ls_api_..."
# LEMON_SQUEEZY_WEBHOOK_SECRET="whsec_..."

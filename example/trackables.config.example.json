  "billing": {
    "lemonSqueezyStoreId": null,
    "manageUrl": null,
    "tiers": []
  },
  "webhooks": {
    "queue": {
      "enabled": true,
      "rateLimitMs": 1000,
      "rateLimitMax": 10
    }
  },

{
  "admins": ["your-email@example.com"],
  "auth": {
    "emailServiceEnabled": false
  },
  "features": {
    "subscriptionEnforcementEnabled": false,
    "workspaceBillingEnabled": false,
    "batchSchedulerEnabled": true,
    "customMCPServerTokens": false,
    "webhooks": true
